diff --git a/doomgeneric/doomgeneric.c b/doomgeneric/doomgeneric.c
index 881d700..6d1d9ab 100644
--- a/doomgeneric/doomgeneric.c
+++ b/doomgeneric/doomgeneric.c
@@ -18,7 +18,9 @@ void doomgeneric_Create(int argc, char **argv)
 
 	M_FindResponseFile();
 
+#ifndef DOOMGENERIC_EXTERNAL_SCREENBUFFER
 	DG_ScreenBuffer = malloc(DOOMGENERIC_RESX * DOOMGENERIC_RESY * 4);
+#endif
 
 	DG_Init();
 
diff --git a/doomgeneric/i_video.c b/doomgeneric/i_video.c
index 84bebde..52c5440 100644
--- a/doomgeneric/i_video.c
+++ b/doomgeneric/i_video.c
@@ -39,6 +39,10 @@ rcsid[] = "$Id: i_x.c,v 1.6 1997/02/03 22:45:10 b1 Exp $";
 
 #include "doomgeneric.h"
 
+#ifdef HAZARD3_SHARED_SCREENBUFFER
+#include "hazard3_platform.h"
+#endif
+
 #include <stdbool.h>
 #include <stdlib.h>
 
@@ -286,8 +290,18 @@ void I_InitGraphics (void)
     }
 
 
-    /* Allocate screen to draw to */
-	I_VideoBuffer = (byte*)Z_Malloc (SCREENWIDTH * SCREENHEIGHT, PU_STATIC, NULL);  // For DOOM to draw on
+    /* Allocate or bind the screen Doom renders into. */
+#ifdef HAZARD3_SHARED_SCREENBUFFER
+    // The monitor reserves a dedicated 64 KiB region in the upper half of the
+    // ULX3S internal SRAM. Keeping the 320x200 working screen on chip prevents
+    // it from evicting hot code, WAD and heap lines from the SDRAM cache.
+    if (hazard3_screen_bytes() < SCREENWIDTH * SCREENHEIGHT)
+        I_Error("Hazard3 internal screen buffer is too small");
+    I_VideoBuffer = (byte*)(uintptr_t)hazard3_screen_base();
+    DG_ScreenBuffer = (pixel_t*)I_VideoBuffer;
+#else
+    I_VideoBuffer = (byte*)Z_Malloc (SCREENWIDTH * SCREENHEIGHT, PU_STATIC, NULL);
+#endif
 
 	screenvisible = true;
 
@@ -297,7 +311,12 @@ void I_InitGraphics (void)
 
 void I_ShutdownGraphics (void)
 {
-	Z_Free (I_VideoBuffer);
+#ifdef HAZARD3_SHARED_SCREENBUFFER
+    DG_ScreenBuffer = NULL;
+    I_VideoBuffer = NULL;
+#else
+    Z_Free (I_VideoBuffer);
+#endif
 }
 
 void I_StartFrame (void)
@@ -320,6 +339,13 @@ void I_UpdateNoBlit (void)
 
 void I_FinishUpdate (void)
 {
+#ifdef HAZARD3_SHARED_SCREENBUFFER
+    // Doom has already rendered directly into DG_ScreenBuffer. The platform
+    // only needs to copy the final 8-bit indices to the uncached staging buffer
+    // and request an atomic hardware presentation.
+    DG_DrawFrame();
+    return;
+#else
     int y;
     int x_offset, y_offset, x_offset_end;
     unsigned char *line_in, *line_out;
@@ -367,6 +393,7 @@ void I_FinishUpdate (void)
     }
 
 	DG_DrawFrame();
+#endif
 }
 
